# Jellyfin server URL. Example: http://192.168.1.50:8096
JELLYFIN_URL=

# Jellyfin API token (Dashboard -> API Keys)
JELLYFIN_API_TOKEN=

# Display settings
REFRESH_SECONDS=30
BACKGROUND_COLOR=black

# Optional comma-separated movie titles. If set, poster rotation only uses these titles.
# Example: SELECT_MOVIES=Inception,The Matrix,Interstellar
SELECT_MOVIES=

# Fade transition speed: 1 (slowest, ~6 s) to 10 (fastest, ~0.06 s). Default: 5 (~0.5 s)
FADE_SPEED=5

# Set to true to run in fullscreen on Raspberry Pi
FULLSCREEN=true
