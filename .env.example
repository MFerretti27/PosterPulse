# Jellyfin server URL. Example: http://192.168.1.50:8096
JELLYFIN_URL=

# Jellyfin API token (Dashboard -> API Keys)
JELLYFIN_API_TOKEN=

# Optional Jellyfin User ID. If blank, the app attempts /Users/Me
JELLYFIN_USER_ID=

# Display settings
REFRESH_SECONDS=30
BACKGROUND_COLOR=black
WINDOW_TITLE=Jellyfin Poster Display

# Set to true to run in fullscreen on Raspberry Pi
FULLSCREEN=true
